# Reference for the values that must be set as `fly secrets` on the
# mobileclient app. This file is NOT loaded by the runtime — Fly's
# secret store is the source of truth. Keep this file in sync with the
# fly.toml [env] block + whatever you import via:
#
#   fly secrets import < .env.production
#
# .env.production itself is gitignored. Copy this template, fill in the
# real values, then use it to import.

# Public URL the app is served at. Used for webhook callback URLs and
# HMAC signature validation — MUST match your Fly app hostname.
SERVER_BASE_URL=https://mobileclient.fly.dev

# Twilio account
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret
TWILIO_AUTH_TOKEN=your_auth_token

TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional regional + feature flags
TWILIO_REGION=
VOICE_SDK_ASSISTANT_SID=
VOICE_SDK_GREETING=
VOICE_SDK_VOICE_ID=
FLEX_WORKFLOW_SID=
FLEX_WORKSPACE_SID=
TRANSCRIPTION_ENGINE=
TRANSCRIPTION_LANGUAGE_CODE=en-AU

OTP_FROM_NUMBER=+15551234567

TWILIO_COUNTRY_CONFIG_AU_TYPE=mobile
TWILIO_COUNTRY_CONFIG_AU_BUNDLE_SID=BUxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_COUNTRY_CONFIG_AU_ADDRESS_SID=ADxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

TWILIO_COUNTRY_CONFIG_US_TYPE=local
