# Copy to apps/web/.env.development.local for local dev.
# Next.js auto-loads .env.development.local when running `next dev`.
#
# Typical local flow:
#   1. Start ngrok pointed at localhost:3000 → copy the https URL below.
#   2. In Twilio console, point your TwiML App Voice URL + numbers'
#      SMS webhook at {SERVER_BASE_URL}/api/… paths.
#   3. `pnpm dev` from the repo root.

# Public URL Twilio reaches — the ngrok https address.
SERVER_BASE_URL=https://your-tunnel.ngrok.dev

# Local SQLite. Relative to apps/web/ at runtime.
DB_PATH=./data/app.db

# Twilio account
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret

# Required for REST API + webhook signature validation. Leave unset in
# dev to bypass validation (useful when ngrok URL changes).
TWILIO_AUTH_TOKEN=

# TwiML App voice URL should point at {SERVER_BASE_URL}/api/voice/outgoing
TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Twilio edge region
TWILIO_REGION=

# Optional: AI Assistant integration
VOICE_SDK_ASSISTANT_SID=
VOICE_SDK_GREETING=
VOICE_SDK_VOICE_ID=

# Optional: Flex TaskRouter integration
FLEX_WORKFLOW_SID=
FLEX_WORKSPACE_SID=

# Optional: real-time transcription (google | deepgram)
TRANSCRIPTION_ENGINE=
TRANSCRIPTION_LANGUAGE_CODE=en-AU

# Dedicated SMS-capable number used for signup OTPs. Per-user numbers
# don't exist until AFTER verification.
OTP_FROM_NUMBER=+15551234567

# Per-country number provisioning — add one block per country you support.
TWILIO_COUNTRY_CONFIG_AU_TYPE=mobile
TWILIO_COUNTRY_CONFIG_AU_BUNDLE_SID=BUxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_COUNTRY_CONFIG_AU_ADDRESS_SID=ADxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

TWILIO_COUNTRY_CONFIG_US_TYPE=local
