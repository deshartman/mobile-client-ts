# ──────────────── Runtime ────────────────

# Public URL Twilio can reach (e.g. your ngrok tunnel) — used as the base for
# webhook callbacks and for HMAC signature validation. MUST be https:// in prod.
SERVER_BASE_URL=https://your-tunnel.ngrok.dev

# Node environment
NODE_ENV=development

# SQLite DB path. In dev this is fine as a relative path under the repo;
# in production on Fly.io we override to /data/app.db (mounted volume).
DB_PATH=./data/app.db


# ──────────────── Twilio account credentials ────────────────

# Account SID + API Key/Secret — used by the Voice SDK AccessToken flow
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret

# Account auth token — required for webhook signature validation AND for the
# REST client used by messaging + number provisioning. This is NOT an API key.
# In dev, leaving this unset disables webhook signature validation (useful
# when ngrok URL is unstable). DO NOT ship to prod without it.
TWILIO_AUTH_TOKEN=

# Optional: Twilio edge region for AccessToken (e.g. au1, ie1, sg1)
TWILIO_REGION=


# ──────────────── Voice ────────────────

# TwiML App SID — its Voice URL must point at {SERVER_BASE_URL}/api/voice/outgoing (POST)
TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — destinationType=assistant uses this AI Assistant for <Connect><Assistant>
VOICE_SDK_ASSISTANT_SID=
# Optional — greeting line spoken before the assistant takes over
VOICE_SDK_GREETING=
# Optional — ElevenLabs voice id for the greeting
VOICE_SDK_VOICE_ID=

# Optional — destinationType=flex uses these for TaskRouter <Enqueue>
FLEX_WORKFLOW_SID=
FLEX_WORKSPACE_SID=

# Optional — real-time call transcription via Twilio's <Transcription> TwiML.
# When TRANSCRIPTION_ENGINE is unset the feature is disabled (no transcription
# is started on calls, no webhooks fire, nothing is persisted). When set,
# <Start><Transcription> is prepended to the TwiML on outbound PSTN dials and
# inbound calls to the user's Twilio number. Engine values: google | deepgram.
# ~$0.027/min per call — every transcribed call incurs this charge.
TRANSCRIPTION_ENGINE=deepgram
TRANSCRIPTION_LANGUAGE_CODE=en-AU


# ──────────────── Messaging (SMS) ────────────────

# Dedicated Twilio number used to send signup/signin OTP SMS. Per-user numbers
# can't send OTPs — they don't exist until AFTER verification completes, so we
# need a single, always-available sender. Must be SMS-capable and live on the
# same account as TWILIO_ACCOUNT_SID.
OTP_FROM_NUMBER=+15551234567


# ──────────────── Number provisioning (per country) ────────────────
#
# One set per country the app supports, keyed by ISO-2. TYPE is one of
# local | mobile | tollFree. BUNDLE_SID + ADDRESS_SID are only required for
# regulated countries (AU mobile requires both; US local requires neither).
#
# On signup, the server picks the country from the E.164 dial code of the
# user's phone and looks up the matching TWILIO_COUNTRY_CONFIG_<ISO>_* values.

# Australia — mobile numbers require a regulatory bundle + address
TWILIO_COUNTRY_CONFIG_AU_TYPE=mobile
TWILIO_COUNTRY_CONFIG_AU_BUNDLE_SID=BUxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_COUNTRY_CONFIG_AU_ADDRESS_SID=ADxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# United States — local numbers, no bundle/address required
TWILIO_COUNTRY_CONFIG_US_TYPE=local
